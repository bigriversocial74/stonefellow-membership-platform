# Stonefellow staging certification environment
SF_ENV=staging
SF_ALLOWED_HOSTS=staging.stonefellow.example.com
SF_TRUST_PROXY=0
SF_SESSION_NAME=stonefellow_staging_session
SF_SESSION_REGENERATE_SECONDS=1800

# Every secret below must be unique. Do not reuse production values.
SF_APP_KEY=replace-with-at-least-64-random-hex-characters
SF_HASH_SALT=replace-with-a-separate-long-random-secret
SF_MEDIA_SIGNING_KEY=replace-with-a-separate-long-random-media-key
SF_AI_SETTINGS_SECRET=replace-with-a-separate-64-character-random-secret
SF_OPS_SCHEDULER_SECRET=replace-with-a-separate-64-character-random-secret
SF_PUBLISHING_RUN_SECRET=replace-with-a-separate-64-character-random-secret
SF_NOTIFICATION_WEBHOOK_SECRET=replace-with-a-separate-64-character-random-secret

SF_DB_HOST=localhost
SF_DB_PORT=3306
SF_DB_NAME=stonefellow_staging
SF_DB_USER=stonefellow_staging_user
SF_DB_PASS=change-me
SF_DB_CHARSET=utf8mb4

# Agentic governance remains supervised during certification
SF_AI_TEXT_REQUEST_ESTIMATED_TOKENS=8000
SF_AI_TEXT_REQUEST_RESERVE_CENTS=25
SF_AI_IMAGE_REQUEST_RESERVE_CENTS=40
SF_AI_TEXT_REQUESTS_PER_15_MIN=20
SF_AI_IMAGE_REQUESTS_PER_15_MIN=8
SF_AI_MAX_BULK_IMAGES=8
SF_AI_RUNNING_LEASE_SECONDS=1800
SF_AI_REQUIRE_DISTINCT_EXECUTOR=1

# Keep production-impacting sandbox shortcuts disabled
SF_ALLOW_ADMIN_PREVIEW=0
SF_ALLOW_PUBLIC_FIRST_ADMIN=0
SF_ALLOW_SANDBOX_SUBSCRIPTIONS=0
SF_ALLOW_SANDBOX_MERCH=0
SF_ALLOW_SANDBOX_PAYMENTS=0
SF_ALLOW_UNSIGNED_SANDBOX_WEBHOOKS=0
SF_ALLOW_INTERNAL_BILLING_WEBHOOK=0
SF_ALLOW_SCHEMA_REPAIR=0

# Payment credentials must use provider test accounts in staging
SF_PAYMENT_PROVIDER=stripe
SF_PAYMENT_MODE=test
SF_STRIPE_PUBLISHABLE_KEY=
SF_STRIPE_SECRET_KEY=
SF_STRIPE_WEBHOOK_SECRET=
SF_BILLING_WEBHOOK_SECRET=
SF_SANDBOX_WEBHOOK_SECRET=

# Use a real transactional staging provider; log/preview does not pass certification
SF_MAIL_PROVIDER=
SF_MAIL_FROM_EMAIL=notifications@staging.stonefellow.example.com
SF_MAIL_FROM_NAME=Stonefellow Staging
SF_ALLOW_LOG_MAIL_PROVIDER=0
SF_ALLOW_PHP_MAIL_PROVIDER=0
SF_NOTIFICATION_MAX_ATTEMPTS=5
SF_NOTIFICATION_RETRY_BASE_SECONDS=60
SF_NOTIFICATION_WEBHOOK_MAX_BYTES=262144

# Certification policy
SF_STAGING_CERT_REQUIRE_DISTINCT_REVIEWER=1
SF_STAGING_CERT_MAX_AGE_HOURS=24
