# Stonefellow Protected Media Storage, CDN & Transcoding v1
# Populate secrets only in the hosting environment. Do not commit real credentials.
SF_MEDIA_STORAGE_DRIVER=local
SF_MEDIA_STORAGE_MODE=test
SF_MEDIA_LOCAL_ROOT=storage/private_media_v2
SF_MEDIA_STAGING_ROOT=storage/media_staging
SF_MEDIA_SIGNING_KEY=
SF_MEDIA_DELIVERY_SESSION_SECRET=
SF_MEDIA_WORKER_SECRET=
SF_MEDIA_BIND_SESSION_FINGERPRINT=1

# Upload and processing controls
SF_MEDIA_UPLOAD_CHUNK_BYTES=8388608
SF_MEDIA_UPLOAD_SESSION_TTL_SECONDS=86400
SF_MEDIA_MAX_AUDIO_BYTES=5368709120
SF_MEDIA_MAX_VIDEO_BYTES=21474836480
SF_MEDIA_MAX_IMAGE_BYTES=52428800
SF_MEDIA_MAX_CAPTION_BYTES=5242880
SF_MEDIA_JOB_LEASE_SECONDS=1800
SF_MEDIA_AUDIO_PREVIEW_SECONDS=30
SF_MEDIA_VIDEO_PREVIEW_SECONDS=60
SF_FFMPEG_PATH=/usr/bin/ffmpeg
SF_FFPROBE_PATH=/usr/bin/ffprobe
SF_AUDIOWAVEFORM_PATH=/usr/bin/audiowaveform

# S3-compatible provider (AWS S3, Cloudflare R2, Wasabi, MinIO, etc.)
SF_MEDIA_S3_ACCESS_KEY=
SF_MEDIA_S3_SECRET_KEY=
SF_MEDIA_S3_SESSION_TOKEN=
SF_MEDIA_S3_BUCKET=
SF_MEDIA_S3_REGION=us-east-1
SF_MEDIA_S3_ENDPOINT=https://s3.amazonaws.com
SF_MEDIA_S3_PATH_STYLE=0

# Optional CDN signed delivery
SF_MEDIA_CDN_BASE_URL=
SF_MEDIA_CDN_SIGNING_KEY=
