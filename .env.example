# Stonefellow production environment template
SF_ENV=production
SF_ALLOWED_HOSTS=stonefellow.example.com,www.stonefellow.example.com
SF_TRUST_PROXY=0
SF_SESSION_NAME=stonefellow_session
SF_SESSION_REGENERATE_SECONDS=1800
SF_APP_KEY=replace-with-at-least-64-random-hex-characters
SF_HASH_SALT=replace-with-a-separate-long-random-secret
SF_MEDIA_SIGNING_KEY=replace-with-a-separate-long-random-media-key
SF_CSP_REPORT_ONLY=0

SF_DB_HOST=localhost
SF_DB_PORT=3306
SF_DB_NAME=stonefellow
SF_DB_USER=stonefellow_user
SF_DB_PASS=change-me
SF_DB_CHARSET=utf8mb4

# Authentication, privacy, and abuse controls
SF_ADMIN_EMAIL=admin@example.com
SF_PASSWORD_MIN_LENGTH=12
SF_LOGIN_FAILURE_LIMIT=10
SF_LOGIN_SESSION_LIMIT=20
SF_LOGIN_WINDOW_SECONDS=900
SF_AUTH_IDLE_SESSION_SECONDS=7200
SF_AUTH_ABSOLUTE_SESSION_SECONDS=43200
SF_ALLOW_REMEMBER_ME=0
SF_SHOW_DEVELOPMENT_RESET_LINK=0
SF_SUBSCRIPTION_GRACE_DAYS=3

# Fail-closed production defaults
SF_ALLOW_ADMIN_PREVIEW=0
SF_ALLOW_PUBLIC_FIRST_ADMIN=0
SF_ALLOW_SANDBOX_SUBSCRIPTIONS=0
SF_ALLOW_SANDBOX_MERCH=0
SF_ALLOW_SANDBOX_PAYMENTS=0
SF_ALLOW_UNSIGNED_SANDBOX_WEBHOOKS=0
SF_ALLOW_INTERNAL_BILLING_WEBHOOK=0

# Operations and recovery
# Enable only during an approved maintenance window. Production also requires
# maintenance mode, an evidence-backed verified backup from the prior 24 hours,
# the exact database confirmation phrase, and a MySQL advisory lock.
SF_ALLOW_SCHEMA_REPAIR=0

# AI / agentic governance
SF_AI_SETTINGS_SECRET=replace-with-a-separate-64-character-random-secret
SF_AI_TEXT_REQUEST_ESTIMATED_TOKENS=8000
SF_AI_TEXT_REQUEST_RESERVE_CENTS=25
SF_AI_IMAGE_REQUEST_RESERVE_CENTS=40
SF_AI_TEXT_REQUESTS_PER_15_MIN=20
SF_AI_IMAGE_REQUESTS_PER_15_MIN=8
SF_AI_MAX_BULK_IMAGES=8
SF_AI_RUNNING_LEASE_SECONDS=1800
SF_AI_REQUIRE_DISTINCT_EXECUTOR=1

# Payments
SF_PAYMENT_PROVIDER=stripe
SF_PAYMENT_MODE=live
SF_STRIPE_PUBLISHABLE_KEY=
SF_STRIPE_SECRET_KEY=
SF_STRIPE_WEBHOOK_SECRET=
SF_BILLING_WEBHOOK_SECRET=
SF_SANDBOX_WEBHOOK_SECRET=
SF_PAYPAL_CLIENT_ID=
SF_PAYPAL_SECRET=
SF_PAYPAL_WEBHOOK_ID=

SF_PUBLISHING_RUN_SECRET=replace-for-cron-if-used
