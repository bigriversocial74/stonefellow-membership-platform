# Stonefellow staging activation and exact-commit release candidate.
SF_ENV=staging
SF_ALLOWED_HOSTS=staging.example.com
SF_TRUST_PROXY=1
SF_RELEASE_COMMIT_SHA=
SF_STAGING_ACTIVATION_SECRET=

# Required adjacent systems. Use unique staging-only values.
SF_APP_KEY=
SF_HASH_SALT=
SF_MEDIA_SIGNING_KEY=
SF_MEDIA_DELIVERY_SESSION_SECRET=
SF_MEDIA_WORKER_SECRET=
SF_CATALOG_RUNNER_SECRET=
SF_OPS_SCHEDULER_SECRET=
SF_PUBLISHING_RUN_SECRET=
SF_NOTIFICATION_WEBHOOK_SECRET=
SF_STRIPE_SECRET_KEY=
SF_STRIPE_WEBHOOK_SECRET=
